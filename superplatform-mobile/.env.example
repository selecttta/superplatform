# ── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Maps (required for TransportScreen map) ──────────────────────────
# Get from: https://console.cloud.google.com → Maps SDK for Android/iOS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Paystack (optional — for card payments via Paystack SDK) ────────────────
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_key

# ── EAS / Expo (for push notifications & builds) ────────────────────────────
# Set via: eas secret:create --scope project --name EXPO_TOKEN --value ...
# EXPO_TOKEN=your-expo-token
