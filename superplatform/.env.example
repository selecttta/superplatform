# ── Supabase ────────────────────────────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# ── Paystack ─────────────────────────────────────────────────────────────────
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_key

# ── Google Maps ──────────────────────────────────────────────────────────────
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ── Supabase Edge Function Secrets (set via supabase CLI) ────────────────────
# supabase secrets set MOMO_API_USER=your-mtn-api-user
# supabase secrets set MOMO_API_KEY=your-mtn-api-key
# supabase secrets set MOMO_ENV=production
# supabase secrets set PAYSTACK_SECRET_KEY=sk_live_xxx
# supabase secrets set TWILIO_ACCOUNT_SID=ACxxx
# supabase secrets set TWILIO_AUTH_TOKEN=xxx
# supabase secrets set TWILIO_PHONE=+1xxxxxxxxxx
